{
  "name": "anything-report",
  "version": "1.0.0",
  "description": "Lightweight ADO query → PowerPoint-style slide deck",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "generate-icon": "node generate-icon.js",
    "electron": "electron .",
    "electron:dev": "electron . --inspect",
    "dist": "electron-builder --win",
    "build": "echo \"No build required\"",
    "build:azure": "echo \"No build required\""
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.anythingReport",
    "productName": "Anything Report",
    "files": [
      "electron/**/*",
      "server.js",
      "index.html",
      "styles.css",
      "pptx-export.js",
      "staticwebapp.config.json",
      "package.json",
      "logo.png",
      "pptx_inspect/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    }
  }
}
